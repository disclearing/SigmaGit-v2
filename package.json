{
  "name": "sigmagit",
  "devDependencies": {
    "prettier": "^3.8.0",
    "turbo": "^2.7.2",
    "typescript": "^5"
  },
  "overrides": {
    "better-auth": "^1.4.12",
    "@better-auth/expo": "^1.4.12",
    "typescript": "^5",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.10",
    "@tanstack/react-query": "^5.90.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "drizzle-orm": "0.45.1",
    "postgres": "^3.4.8",
    "bcryptjs": "^3.0.3",
    "@types/bcryptjs": "^3.0.0"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "dev:web": "turbo dev --filter=@sigmagit/web --filter=@sigmagit/api --filter=@sigmagit/docs-vitepress",
    "dev:mobile": "turbo dev --filter=@sigmagit/mobile --filter=@sigmagit/api --filter=@sigmagit/discord-bot",
    "dev:docs": "turbo dev --filter=@sigmagit/docs-vitepress",
    "dev:discord": "turbo dev --filter=@sigmagit/discord-bot",
    "build": "turbo build",
    "build:docs": "turbo build --filter=@sigmagit/docs-vitepress",
    "lint": "turbo lint",
    "db:migrate:discord": "cd packages/db && bun run db:migrate:discord",
    "discord:register": "cd apps/discord-bot && bun run register",
    "build:runner": "cd apps/runner && make build-agent"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
