# Database
DATABASE_URL=""

# Storage Configuration
STORAGE_TYPE="s3"                       # "s3" or "local"
STORAGE_LOCAL_PATH="./data/repos"       # Used if STORAGE_TYPE=local

# S3 Storage (only needed if STORAGE_TYPE=s3)
S3_ENDPOINT="https://storage.railway.app"
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Redis (optional, for caching and notifications)
REDIS_URL=""

# Auth Secrets
BETTER_AUTH_SECRET=""

# Web Platform URLs
WEB_URL="http://localhost:3000"         # Public web frontend URL
EXPO_PUBLIC_API_URL="http://localhost:3001"    # API endpoint for mobile/web

# Email Configuration
EMAIL_PROVIDER="resend"                 # "resend" or "smtp"

# Resend (only needed if EMAIL_PROVIDER=resend)
RESEND_API_KEY=""

# SMTP (only needed if EMAIL_PROVIDER=smtp)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

EMAIL_FROM="Sigmagit <noreply@sigmagit.dev>"

# Discord Bot Configuration (for standalone bot app)
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_GUILD_ID=""

# Webhooks (set to false to disable all webhook routes and delivery)
ENABLE_WEBHOOKS="true"

# Discord Webhook Configuration (for notifications from API)
DISCORD_WEBHOOK_URL="http://your-domain.com/api/webhooks/discord"
WEBHOOK_SECRET="sigmagit-webhook-secret"
PUBLIC_WEBHOOK_URL="http://localhost:3001/api/webhooks/discord"

# Discord Bot Account Linking (used for linking Discord and Sigmagit accounts)
# (Note: These may be duplicated for standalone bot/app; ensure consistency if so)
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""