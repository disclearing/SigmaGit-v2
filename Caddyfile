{
    # Global options
    email your-email@example.com
}

# Replace with your actual domain or localhost for testing
sigmagit.com {
    # API requests
    handle_path /api/* {
        reverse_proxy localhost:3001
    }

    # Auth requests (Better Auth)
    handle_path /api/auth/* {
        reverse_proxy localhost:3001
    }

    # Web app (TanStack Start)
    handle {
        reverse_proxy localhost:3000
    }

    # Git LFS / Large uploads configuration
    request_body {
        max_size 500MB
    }

    # Compression
    encode zstd gzip

    # Logging
    log {
        output file /var/log/caddy/sigmagit.log
    }
}

# Documentation site
docs.sigmagit.com {
    reverse_proxy localhost:3003

    # Compression
    encode zstd gzip

    # Logging
    log {
        output file /var/log/caddy/sigmagit-docs.log
    }
}
